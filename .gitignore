# ============================================================================
# MedSeg3D Research .gitignore
# ============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyc

# ---------- Virtual Environments ----------
.venv/
venv/
env/
.conda/
*.conda

# ---------- Testing ----------
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Data & Raw Medical Images ----------
data/
*.nii
*.nii.gz
*.nrrd
*.mha
*.stl
*.dcm
*.dicom

# ---------- Model Weights & Checkpoints ----------
*.pt
*.pth
*.ckpt
checkpoints/
saved_models/

# ---------- Experiment Results (keep small JSON summaries) ----------
!results/*.json
results/
mlruns/
mlflow.db

# ---------- Logs ----------
*.log
logs/

# ---------- CUDA / GPU Cache ----------
*.cuda_cache/
.cupti*

# ---------- Secrets ----------
.env
.env.*
secrets/
*.pem
*.key

# ---------- LaTeX / Paper Build ----------
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/*.toc

# ---------- Large numpy arrays ----------
*.npz
*.npy

# ---------- Temporary files ----------
*.bak
*.tmp
*.temp
.cache/

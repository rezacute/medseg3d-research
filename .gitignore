# ============================================================================
# QRC-EV .gitignore
# Python / Quantum Computing / Data Science / Research Project
# ============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ---------- Distribution / Packaging ----------
build/
dist/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
MANIFEST
src/*.egg-info/

# ---------- Virtual Environments ----------
.venv/
venv/
env/
ENV/
.conda/
*.conda

# ---------- Testing ----------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# ---------- Type Checking / Linting ----------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ---------- Jupyter Notebooks ----------
.ipynb_checkpoints/
*.ipynb_metadata/

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-project
*.sublime-workspace

# ---------- OS ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# ---------- Data (large files, raw datasets) ----------
data/raw/
data/processed/
data/interim/
data/external/
*.parquet
*.h5
*.hdf5
*.feather
*.pkl
*.pickle
!data/.gitkeep

# ---------- Experiment Results / MLflow ----------
results/
mlruns/
mlflow.db
*.json.lock

# ---------- Model Checkpoints ----------
checkpoints/
*.pt
*.pth
*.ckpt
saved_models/

# ---------- Logs ----------
logs/
*.log

# ---------- Quantum Backend Caches ----------
.qiskit/
.pennylane/

# ---------- IBM Quantum Credentials ----------
qiskitrc
ibm_quantum_token.txt

# ---------- Paper / LaTeX Build Artifacts ----------
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.lof
paper/*.lot
paper/*.nav
paper/*.snm
paper/*.vrb
paper/*.run.xml
paper/*.bcf
paper/*-blx.bib

# ---------- Secrets / Credentials ----------
.env
.env.*
secrets/
*.pem
*.key

# ---------- Misc ----------
*.bak
*.tmp
*.temp
.cache/
